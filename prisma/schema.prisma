generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PlatformAdminStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum StaffUserStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum BranchRoleStatus {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  SUPERVISOR
  WAITER
  KITCHEN
  BAR
  CASHIER
}

enum MenuStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MenuCategoryStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  DISABLED
}

enum TableSessionOpenedBySource {
  QR
  WAITER
  HOST
  CASHIER
}

enum TableSessionStatus {
  OPEN
  PAYMENT_COMPLETED
  CLOSED
  ABANDONED
}

enum MenuItemType {
  FOOD
  DRINK
  DESSERT
  PACKAGED
  SERVICE
}

enum ModifierSelectionType {
  ONE
  MANY
}

enum PreparationStationType {
  KITCHEN
  BAR
  DESSERT
  COFFEE
  OTHER
}

enum PreparationStationStatus {
  ACTIVE
  INACTIVE
}

enum OrderSource {
  QR
  WAITER
  MIXED
}

enum PaymentPolicy {
  PREPAID
  POSTPAID
}

enum OrderStatus {
  DRAFT
  AWAITING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  ROUTED
  IN_PREPARATION
  PARTIALLY_READY
  READY
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  IN_PREPARATION
  READY
  DELIVERED
  CANCELLED
}

enum StationTicketStatus {
  PENDING
  IN_PROGRESS
  READY
  CANCELLED
}

enum BillStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  ABANDONED
  VOID
}

enum BillItemStatus {
  OPEN
  PAID
  VOID
  REFUNDED
}

enum BillSplitMode {
  BY_ITEM
  BY_AMOUNT
  BY_PERCENTAGE
}

enum BillSplitStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum BillSplitParticipantStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentAttemptStatus {
  PENDING
  FAILED
  SUCCEEDED
  CANCELLED
}

enum TranslationEntityType {
  MENU
  MENU_CATEGORY
  MENU_ITEM
}

enum LeadIntent {
  DEMO_REQUEST
  GENERAL_INQUIRY
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Restaurant {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  legalName       String?          @map("legal_name")
  slug            String           @unique
  branchQuota     Int              @default(1) @map("branch_quota")
  defaultLanguage String           @default("es") @map("default_language")
  timezone        String           @default("America/Santiago")
  currency        String           @default("CLP")
  status          RestaurantStatus @default(ACTIVE)
  branches        Branch[]
  staffUsers      StaffUser[]
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("restaurants")
}

model Branch {
  id                  String                @id @default(uuid()) @db.Uuid
  restaurantId        String                @map("restaurant_id") @db.Uuid
  name                String
  address             String?
  status              BranchStatus          @default(ACTIVE)
  restaurant          Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  settings            BranchSettings?
  staffUserRoles      StaffUserBranchRole[]
  tables              Table[]
  tableSessions       TableSession[]
  menus               Menu[]
  preparationStations PreparationStation[]
  orders              Order[]
  bills               Bill[]
  modifierGroups      ModifierGroup[]
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  stationTickets      StationTicket[]

  @@index([restaurantId])
  @@map("branches")
}

model BranchSettings {
  branchId               String   @id @map("branch_id") @db.Uuid
  qrOrderingEnabled      Boolean  @default(true) @map("qr_ordering_enabled")
  qrPaymentMode          String   @default("prepaid_order") @map("qr_payment_mode")
  splitBillEnabled       Boolean  @default(true) @map("split_bill_enabled")
  partialDeliveryEnabled Boolean  @default(true) @map("partial_delivery_enabled")
  autoDeliverAfterMinutes Int?    @map("auto_deliver_after_minutes")
  defaultMenuId          String?  @map("default_menu_id") @db.Uuid
  branch                 Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  defaultMenu            Menu?    @relation("BranchDefaultMenu", fields: [defaultMenuId], references: [id], onDelete: SetNull)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([defaultMenuId])
  @@map("branch_settings")
}

model StaffUser {
  id             String                @id @default(uuid()) @db.Uuid
  authUserId     String                @map("auth_user_id") @db.Uuid
  restaurantId   String                @map("restaurant_id") @db.Uuid
  firstName      String                @map("first_name")
  lastName       String                @map("last_name")
  status         StaffUserStatus       @default(INVITED)
  restaurant     Restaurant            @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  branchRoles    StaffUserBranchRole[]
  openedSessions TableSession[]        @relation("TableSessionOpenedBy")
  closedSessions TableSession[]        @relation("TableSessionClosedBy")
  createdOrders  Order[]               @relation("OrderCreatedBy")
  resolvedBills  Bill[]                @relation("BillResolvedBy")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([authUserId, restaurantId])
  @@index([restaurantId])
  @@map("staff_users")
}

model PlatformAdmin {
  id         String              @id @default(uuid()) @db.Uuid
  authUserId String              @map("auth_user_id") @db.Uuid
  firstName  String              @map("first_name")
  lastName   String              @map("last_name")
  status     PlatformAdminStatus @default(INVITED)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([authUserId])
  @@map("platform_admins")
}

model StaffUserBranchRole {
  id          String           @id @default(uuid()) @db.Uuid
  staffUserId String           @map("staff_user_id") @db.Uuid
  branchId    String           @map("branch_id") @db.Uuid
  role        Role
  status      BranchRoleStatus @default(ACTIVE)
  staffUser   StaffUser        @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([staffUserId, branchId, role])
  @@index([branchId])
  @@map("staff_user_branch_roles")
}

model Table {
  id            String         @id @default(uuid()) @db.Uuid
  branchId      String         @map("branch_id") @db.Uuid
  code          String
  name          String
  capacity      Int?
  qrToken       String         @unique @map("qr_token")
  status        TableStatus    @default(AVAILABLE)
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableSessions TableSession[]
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([branchId, code])
  @@map("tables")
}

model TableSession {
  id                  String                     @id @default(uuid()) @db.Uuid
  tableId             String                     @map("table_id") @db.Uuid
  branchId            String                     @map("branch_id") @db.Uuid
  status              TableSessionStatus         @default(OPEN)
  openedBySource      TableSessionOpenedBySource @map("opened_by_source")
  openedByStaffUserId String?                    @map("opened_by_staff_user_id") @db.Uuid
  closedByStaffUserId String?                    @map("closed_by_staff_user_id") @db.Uuid
  closeReason         String?                    @map("close_reason")
  openedAt            DateTime                   @default(now()) @map("opened_at") @db.Timestamptz(3)
  closedAt            DateTime?                  @map("closed_at") @db.Timestamptz(3)
  table               Table                      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  branch              Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedByStaffUser   StaffUser?                 @relation("TableSessionOpenedBy", fields: [openedByStaffUserId], references: [id], onDelete: SetNull)
  closedByStaffUser   StaffUser?                 @relation("TableSessionClosedBy", fields: [closedByStaffUserId], references: [id], onDelete: SetNull)
  bill                Bill?
  orders              Order[]
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([tableId])
  @@index([branchId, status])
  @@map("table_sessions")
}

model Menu {
  id                    String           @id @default(uuid()) @db.Uuid
  branchId              String           @map("branch_id") @db.Uuid
  name                  String
  status                MenuStatus       @default(DRAFT)
  version               Int              @default(1)
  publishedAt           DateTime?        @map("published_at") @db.Timestamptz(3)
  defaultLanguage       String           @default("es") @map("default_language")
  branch                Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categories            MenuCategory[]
  branchDefaultSettings BranchSettings[] @relation("BranchDefaultMenu")
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([branchId, version])
  @@index([branchId, status])
  @@map("menus")
}

model MenuCategory {
  id        String             @id @default(uuid()) @db.Uuid
  menuId    String             @map("menu_id") @db.Uuid
  name      String
  sortOrder Int                @default(0) @map("sort_order")
  status    MenuCategoryStatus @default(ACTIVE)
  menu      Menu               @relation(fields: [menuId], references: [id], onDelete: Cascade)
  items     MenuItem[]
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([menuId, sortOrder])
  @@map("menu_categories")
}

model PreparationStation {
  id             String                   @id @default(uuid()) @db.Uuid
  branchId       String                   @map("branch_id") @db.Uuid
  name           String
  stationType    PreparationStationType   @map("station_type")
  status         PreparationStationStatus @default(ACTIVE)
  branch         Branch                   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menuItems      MenuItem[]
  orderItems     OrderItem[]
  stationTickets StationTicket[]
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([branchId, name])
  @@index([branchId, stationType])
  @@map("preparation_stations")
}

model MenuItem {
  id                   String             @id @default(uuid()) @db.Uuid
  menuCategoryId       String             @map("menu_category_id") @db.Uuid
  name                 String
  description          String?
  price                Decimal            @db.Decimal(12, 2)
  sku                  String?
  itemType             MenuItemType       @map("item_type")
  preparationStationId String             @map("preparation_station_id") @db.Uuid
  isAvailable          Boolean            @default(true) @map("is_available")
  sortOrder            Int                @default(0) @map("sort_order")
  menuCategory         MenuCategory       @relation(fields: [menuCategoryId], references: [id], onDelete: Cascade)
  preparationStation   PreparationStation @relation(fields: [preparationStationId], references: [id], onDelete: Restrict)
  media                MenuItemMedia[]
  orderItems           OrderItem[]
  modifierGroups       MenuItemModifierGroup[]
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([menuCategoryId, isAvailable])
  @@index([menuCategoryId, sortOrder])
  @@index([preparationStationId])
  @@map("menu_items")
}

model MenuItemMedia {
  id         String   @id @default(uuid()) @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  mediaType  String   @map("media_type")
  url        String
  sortOrder  Int      @default(0) @map("sort_order")
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([menuItemId, sortOrder])
  @@map("menu_item_media")
}

model ModifierGroup {
  id            String                  @id @default(uuid()) @db.Uuid
  branchId      String                  @map("branch_id") @db.Uuid
  name          String
  selectionType ModifierSelectionType   @map("selection_type")
  minSelect     Int                     @default(0) @map("min_select")
  maxSelect     Int?                    @map("max_select")
  isRequired    Boolean                 @default(false) @map("is_required")
  sortOrder     Int                     @default(0) @map("sort_order")
  branch        Branch                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  options       ModifierOption[]
  menuItems     MenuItemModifierGroup[]
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([branchId])
  @@map("modifier_groups")
}

model ModifierOption {
  id                 String              @id @default(uuid()) @db.Uuid
  modifierGroupId    String              @map("modifier_group_id") @db.Uuid
  name               String
  priceDelta         Decimal             @default(0) @map("price_delta") @db.Decimal(12, 2)
  isAvailable        Boolean             @default(true) @map("is_available")
  sortOrder          Int                 @default(0) @map("sort_order")
  modifierGroup      ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([modifierGroupId, sortOrder])
  @@map("modifier_options")
}

model MenuItemModifierGroup {
  id              String        @id @default(uuid()) @db.Uuid
  menuItemId      String        @map("menu_item_id") @db.Uuid
  modifierGroupId String        @map("modifier_group_id") @db.Uuid
  sortOrder       Int           @default(0) @map("sort_order")
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([menuItemId, modifierGroupId])
  @@index([modifierGroupId])
  @@map("menu_item_modifier_groups")
}

model Translation {
  id              String                @id @default(uuid()) @db.Uuid
  entityType      TranslationEntityType @map("entity_type")
  entityId        String                @map("entity_id") @db.Uuid
  locale          String
  fieldName       String                @map("field_name")
  translatedValue String                @map("translated_value")
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([entityType, entityId, locale, fieldName])
  @@map("translations")
}

model Bill {
  id                    String           @id @default(uuid()) @db.Uuid
  tableSessionId        String           @unique @map("table_session_id") @db.Uuid
  branchId              String           @map("branch_id") @db.Uuid
  status                BillStatus       @default(OPEN)
  subtotalAmount        Decimal          @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  taxAmount             Decimal          @default(0) @map("tax_amount") @db.Decimal(12, 2)
  tipAmount             Decimal          @default(0) @map("tip_amount") @db.Decimal(12, 2)
  totalAmount           Decimal          @default(0) @map("total_amount") @db.Decimal(12, 2)
  remainingAmount       Decimal          @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  resolvedByStaffUserId String?          @map("resolved_by_staff_user_id") @db.Uuid
  closeReason           String?          @map("close_reason")
  openedAt              DateTime         @default(now()) @map("opened_at") @db.Timestamptz(3)
  closedAt              DateTime?        @map("closed_at") @db.Timestamptz(3)
  tableSession          TableSession     @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  branch                Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  resolvedByStaffUser   StaffUser?       @relation("BillResolvedBy", fields: [resolvedByStaffUserId], references: [id], onDelete: SetNull)
  orders                Order[]
  billItems             BillItem[]
  billSplits            BillSplit[]
  payments              Payment[]
  paymentAttempts       PaymentAttempt[]
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([branchId, status])
  @@map("bills")
}

model Order {
  id                   String           @id @default(uuid()) @db.Uuid
  tableSessionId       String           @map("table_session_id") @db.Uuid
  billId               String           @map("bill_id") @db.Uuid
  branchId             String           @map("branch_id") @db.Uuid
  source               OrderSource
  paymentPolicy        PaymentPolicy    @map("payment_policy")
  status               OrderStatus      @default(DRAFT)
  createdByStaffUserId String?          @map("created_by_staff_user_id") @db.Uuid
  submittedAt          DateTime?        @map("submitted_at") @db.Timestamptz(3)
  notes                String?
  tableSession         TableSession     @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  bill                 Bill             @relation(fields: [billId], references: [id], onDelete: Cascade)
  branch               Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdByStaffUser   StaffUser?       @relation("OrderCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  orderItems           OrderItem[]
  stationTickets       StationTicket[]
  paymentAttempts      PaymentAttempt[]
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([tableSessionId])
  @@index([billId])
  @@index([branchId, status])
  @@map("orders")
}

model OrderItem {
  id                   String              @id @default(uuid()) @db.Uuid
  orderId              String              @map("order_id") @db.Uuid
  menuItemId           String?             @map("menu_item_id") @db.Uuid
  preparationStationId String              @map("preparation_station_id") @db.Uuid
  nameSnapshot         String              @map("name_snapshot")
  priceSnapshot        Decimal             @map("price_snapshot") @db.Decimal(12, 2)
  quantity             Int
  status               OrderItemStatus     @default(PENDING)
  notes                String?
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem             MenuItem?           @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  preparationStation   PreparationStation  @relation(fields: [preparationStationId], references: [id], onDelete: Restrict)
  stationTicketItems   StationTicketItem[]
  billItems            BillItem[]
  modifiers            OrderItemModifier[]
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([orderId])
  @@index([preparationStationId, status])
  @@map("order_items")
}

model OrderItemModifier {
  id                 String          @id @default(uuid()) @db.Uuid
  orderItemId        String          @map("order_item_id") @db.Uuid
  modifierOptionId   String?         @map("modifier_option_id") @db.Uuid
  nameSnapshot       String          @map("name_snapshot")
  priceDeltaSnapshot Decimal         @map("price_delta_snapshot") @db.Decimal(12, 2)
  orderItem          OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption     ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

model StationTicket {
  id                   String              @id @default(uuid()) @db.Uuid
  orderId              String              @map("order_id") @db.Uuid
  branchId             String              @map("branch_id") @db.Uuid
  preparationStationId String              @map("preparation_station_id") @db.Uuid
  status               StationTicketStatus @default(PENDING)
  sentAt               DateTime?           @map("sent_at") @db.Timestamptz(3)
  startedAt            DateTime?           @map("started_at") @db.Timestamptz(3)
  completedAt          DateTime?           @map("completed_at") @db.Timestamptz(3)
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branch               Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  preparationStation   PreparationStation  @relation(fields: [preparationStationId], references: [id], onDelete: Restrict)
  stationTicketItems   StationTicketItem[]
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([orderId])
  @@index([branchId, preparationStationId, status])
  @@map("station_tickets")
}

model StationTicketItem {
  id              String          @id @default(uuid()) @db.Uuid
  stationTicketId String          @map("station_ticket_id") @db.Uuid
  orderItemId     String          @map("order_item_id") @db.Uuid
  quantity        Int
  status          OrderItemStatus @default(PENDING)
  stationTicket   StationTicket   @relation(fields: [stationTicketId], references: [id], onDelete: Cascade)
  orderItem       OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([stationTicketId, orderItemId])
  @@map("station_ticket_items")
}

model BillItem {
  id          String         @id @default(uuid()) @db.Uuid
  billId      String         @map("bill_id") @db.Uuid
  orderItemId String?        @map("order_item_id") @db.Uuid
  description String
  quantity    Int
  unitPrice   Decimal        @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal        @map("total_price") @db.Decimal(12, 2)
  status      BillItemStatus @default(OPEN)
  bill        Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  orderItem   OrderItem?     @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([billId])
  @@index([orderItemId])
  @@map("bill_items")
}

model BillSplit {
  id           String                 @id @default(uuid()) @db.Uuid
  billId       String                 @map("bill_id") @db.Uuid
  splitMode    BillSplitMode          @map("split_mode")
  status       BillSplitStatus        @default(OPEN)
  bill         Bill                   @relation(fields: [billId], references: [id], onDelete: Cascade)
  participants BillSplitParticipant[]
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([billId, status])
  @@map("bill_splits")
}

model BillSplitParticipant {
  id               String                     @id @default(uuid()) @db.Uuid
  billSplitId      String                     @map("bill_split_id") @db.Uuid
  participantToken String                     @map("participant_token")
  displayName      String?                    @map("display_name")
  allocatedAmount  Decimal                    @default(0) @map("allocated_amount") @db.Decimal(12, 2)
  paidAmount       Decimal                    @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status           BillSplitParticipantStatus @default(PENDING)
  billSplit        BillSplit                  @relation(fields: [billSplitId], references: [id], onDelete: Cascade)
  payments         Payment[]
  createdAt        DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([billSplitId, status])
  @@map("bill_split_participants")
}

model Payment {
  id                     String                @id @default(uuid()) @db.Uuid
  billId                 String                @map("bill_id") @db.Uuid
  billSplitParticipantId String?               @map("bill_split_participant_id") @db.Uuid
  amount                 Decimal               @db.Decimal(12, 2)
  currency               String                @default("CLP")
  provider               String
  providerReference      String?               @map("provider_reference")
  status                 PaymentStatus         @default(PENDING)
  paidAt                 DateTime?             @map("paid_at") @db.Timestamptz(3)
  bill                   Bill                  @relation(fields: [billId], references: [id], onDelete: Cascade)
  billSplitParticipant   BillSplitParticipant? @relation(fields: [billSplitParticipantId], references: [id], onDelete: SetNull)
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([billId, status])
  @@index([billSplitParticipantId])
  @@map("payments")
}

model PaymentAttempt {
  id                String               @id @default(uuid()) @db.Uuid
  orderId           String?              @map("order_id") @db.Uuid
  billId            String?              @map("bill_id") @db.Uuid
  amount            Decimal?             @db.Decimal(12, 2)
  provider          String
  providerReference String?              @map("provider_reference")
  status            PaymentAttemptStatus @default(PENDING)
  failureReason     String?              @map("failure_reason")
  order             Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bill              Bill?                @relation(fields: [billId], references: [id], onDelete: Cascade)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([orderId, status])
  @@index([billId, status])
  @@map("payment_attempts")
}

model Lead {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String?
  businessName String?    @map("business_name")
  intent       LeadIntent @default(GENERAL_INQUIRY)
  message      String?
  status       LeadStatus @default(NEW)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([status, createdAt])
  @@map("leads")
}
