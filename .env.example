# NestJS
NODE_ENV=development
PORT=3000
API_PREFIX=api
SWAGGER_ENABLED=true
LOG_LEVEL=info
CORS_ENABLED=true
CORS_ORIGIN=*
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
JWT_ACCESS_TOKEN_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_IN=15m

# Prisma
PRISMA_CONNECT_ON_STARTUP=false

# Tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sazono-backend-monolith
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_DEBUG=false

# Supabase / Postgres
# For long-running servers, Supabase recommends the Session pooler string.
# If you also have a direct connection available, keep it in DIRECT_URL for migrations/troubleshooting.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[SESSION_POOLER_HOST]:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
