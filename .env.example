# NestJS
NODE_ENV=development
PORT=3000
API_PREFIX=api
SWAGGER_ENABLED=true
LOG_LEVEL=info
CORS_ENABLED=true
CORS_ORIGIN=*

# Rate limiting (ThrottlerModule)
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# Auth interna (JWT emitido por este backend tras login con Supabase)
JWT_ACCESS_TOKEN_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_IN=8h
JWT_REFRESH_TOKEN_SECRET=change-me-refresh
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# Supabase Auth (identidad compartida; perfiles en platform_admins / staff_users)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma
# PRISMA_CONNECT_ON_STARTUP=true intenta conectar al arrancar (util en prod)
PRISMA_CONNECT_ON_STARTUP=false

# OpenTelemetry (opcional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sazono-backend-monolith
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_DEBUG=false

# Postgres (Supabase)
# DATABASE_URL: pooler de sesion para la app en runtime
# DIRECT_URL: conexion directa para migraciones Prisma (prisma migrate)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[SESSION_POOLER_HOST]:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
